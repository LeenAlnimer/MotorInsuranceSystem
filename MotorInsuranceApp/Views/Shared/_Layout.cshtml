<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Motor Insurance</title>

    <link rel="stylesheet" href="~/css/site.css" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
</head>

<body>

    <div class="layout">

        <!-- Sidebar -->
        <div class="sidebar">

            <h4 class="logo">Motor Insurance</h4>

            <a asp-controller="Home" asp-action="Index"
                   class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Index" ? "active" : "")">
                <i class="bi bi-grid"></i> Dashboard
            </a>

            <a asp-controller="Home" asp-action="Cars"
                   class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Cars" ? "active" : "")">
                <i class="bi bi-car-front"></i> Cars
            </a>

            <a asp-controller="Home" asp-action="Customers"
                   class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Customers" ? "active" : "")">
                <i class="bi bi-people"></i> Customers
            </a>

            <a asp-controller="Home" asp-action="Policies"
                   class="nav-link @(ViewContext.RouteData.Values["action"].ToString() == "Policies" ? "active" : "")">
                <i class="bi bi-file-earmark-text"></i> Policies
            </a>

        </div>

        <!-- Main -->
        <div class="main">

            <div class="topbar">
                <h5>Motor Insurance Management System</h5>
                <i class="bi bi-person-circle user-icon"></i>
            </div>

            <div class="page-content">
                @RenderBody()
            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>